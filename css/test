* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: "Playfair Display", "Comic Sans MS", "Arial", sans-serif;
  background: linear-gradient(135deg, #15105b 0%, #1a176e 50%, #2e245c 100%);
  padding: 30px;
  min-height: 100vh;
  /* For a luxe shimmer effect */
  background-attachment: fixed;
}

.title{
    font-size: 64px;
    text-align: center;
    color: #fff ef;
    text-shadow: 0 2px 30px #d4af37, 0 0 2px #fffbda, 0 0 50px #402c7f;
    font-family: "Cinzel Decorative", "Playfair Display", serif;
    letter-spacing: 0.07em;
    font-weight: 900;
    background: linear-gradient(90deg, #fff8dc 60%, #eebb66 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.description{
    font-size: 28px;
    margin-top: 30px;
    text-align: center;
    color: #e6ae38;
    font-weight: 700;
    text-shadow: 0 2px 4px #342f2d70;
    font-family: "Playfair Display", serif;
}

.levels-container {
  display: grid;
  margin-top: 140px;
  grid-template-columns: repeat(auto-fit, minmax(345px, 1fr));
  gap: 3.5rem;
  width: 100%;
  /* Subtle gold shadow for luxe */
  filter: drop-shadow(0 0 18px #ffe66fde);
}

.levels-container a {
  text-decoration: none;
  color: #fff8dc;
  font-size: 22px;
  font-weight: 700;
  border-radius: 28px;
  padding: 16px 28px;
  background: linear-gradient(100deg, #e2b778 10%, #8B6F43 90%);
  border: 2.5px solid #e6ae38;
  box-shadow: 0 4px 18px #e6ae3895, 0 0.5px 0px #fff3ed34;
  transition: all 0.25s cubic-bezier(.57,.21,.69,1.25);
  margin-left: 0;
  display: inline-block;
  letter-spacing: 0.04em;

  &:hover {
    background: linear-gradient(90deg, #fffadd, #e6ae38 80%);
    color: #1d153b;
    border-color: #fff8dc;
    transform: translateY(-5px) scale(1.07) rotate(-2deg);
    box-shadow: 0 8px 32px 0 #f9e982d5, 0 2px 8px #e6ae38c1;
    text-shadow: 0 1px 7px #ffd700;
  }
}

.space,
.auto,
.hardware,
.dieren {
  padding: 110px 28px;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  transition: all 0.35s cubic-bezier(.4,2,.6,1);
  border-radius: 25px;
  box-shadow: 0 2px 40px #d4af379a, 0 0px 0px #0000;
  outline: 2px solid #bfa45d66;
  position: relative;
  overflow: hidden;
}

.space {
  background-image: url(/assets/backgrounds/space.jpg);
}

.auto {
  background-image: url(/assets/backgrounds/auto.jpg);
}

.hardware {
  background-image: url(/assets/backgrounds/hardware.jpg);
}

.dieren {
  background-image: url(/assets/backgrounds/dieren.jpg);
}

.space::after,
.auto::after,
.hardware::after,
.dieren::after {
  /* Subtle vignette overlay for depth */
  content: '';
  position: absolute;
  top:0; left:0; width:100%; height:100%;
  background: radial-gradient(ellipse at center, transparent 60%, #0b0839c7 100%);
  border-radius: inherit;
  z-index: 1;
  pointer-events: none;
}

.space:hover,
.auto:hover,
.hardware:hover,
.dieren:hover {
  transform: scale(1.055) translateY(-3px);
  box-shadow: 0 9px 48px #f9e982cf, 0 0px 12px #e6ae38c7;
  border-color: #ffe066;
}

.space:active,
.auto:active,
.hardware:active,
.dieren:active {
  transform: scale(1.025);
  box-shadow: 0 3px 22px #e6ae38b5, 0 0px 6px #ffe06698;
  border-color: #dcc788;
}

/* Unique colored drop-shadows for each */
.space {
  box-shadow: 0 2px 44px #8caaff66, 0 0px 0px #0000;
}
.auto {
  box-shadow: 0 2px 44px #003cff66, 0 0px 0px #e6ae389a;
}
.hardware {
  box-shadow: 0 2px 44px #ff260066, 0 0px 0px #40396394;
}
.dieren {
  box-shadow: 0 2px 44px #3cff0093, 0 0px 0px #1faf18a2;
}


.footer{
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 44px 26px 36px 26px;
  background: linear-gradient(90deg, #1c1c1c 70%, #e6ae38 170%);
  color: #fff8dc;
  text-align: center;
  border-radius: 18px 18px 0 0;
  box-shadow: 0 -4px 26px #bfa45d7c;
  font-size: 1.18rem;
  letter-spacing: 0.08em;
  margin-top: 0;
  font-family: "Playfair Display", serif;

  a {
    color: #ffe066;
    text-decoration: underline double;
    transition: color 0.18s, text-shadow 0.18s;
    text-shadow: 0 2px 9px #ffd7009a;
    font-weight: 700;
  }

  a:hover {
    color: #e99632;
    text-shadow: 0 2px 18px #fffbe7, 0 0 8px #ffe066ba;
  }
}